{
  "name": "llem",
  "displayName": "LLeM",
  "description": "A local-first coding sidekick for VS Code and Cursor. Stream live model output, chat with your repo, edit files, run terminal commands, and keep everything on-device.",
  "version": "2.2.34",
  "publisher": "nIcK",
  "author": "nIcK",
  "repository": {
    "type": "git",
    "url": "https://github.com/heroyik/llem"
  },
  "license": "MIT",
  "icon": "assets/icon.png",
  "activationEvents": [],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Chat"
  ],
  "keywords": [
    "ai",
    "local",
    "local-first",
    "ollama",
    "gemma",
    "llama",
    "deepseek",
    "offline",
    "agent",
    "coding-assistant",
    "developer-tools",
    "code-generation",
    "llem",
    "lm-studio",
    "vscode-extension",
    "cursor",
    "markdown-vault",
    "copilot"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "llem.openChat",
        "title": "LLeM: Open Console",
        "icon": {
          "light": "assets/open-chat-light.svg",
          "dark": "assets/open-chat-dark.svg"
        }
      },
      {
        "command": "llem.newChat",
        "title": "LLeM: New Thread",
        "icon": "$(add)"
      },
      {
        "command": "llem.exportChat",
        "title": "LLeM: Export Thread as Markdown"
      },
      {
        "command": "llem.explainSelection",
        "title": "LLeM: Break Down Selection"
      },
      {
        "command": "llem.focusChat",
        "title": "LLeM: Focus Prompt"
      },
      {
        "command": "llem.showVaultMap",
        "title": "LLeM: Open Vault Map"
      }
    ],
    "keybindings": [
      {
        "command": "llem.focusChat",
        "key": "cmd+l",
        "mac": "cmd+l"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "llem.openChat",
          "group": "navigation@99"
        }
      ],
      "editor/context": [
        {
          "command": "llem.explainSelection",
          "when": "editorHasSelection",
          "group": "1_modification"
        }
      ]
    },
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "llem",
          "title": "LLeM",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "llem": [
        {
          "type": "webview",
          "id": "llem.chat",
          "name": "LLeM",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "configuration": {
      "title": "LLeM",
      "properties": {
        "llem.engineUrl": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "Local model endpoint. Point it at Ollama or LM Studio and let it cook."
        },
        "llem.defaultModel": {
          "type": "string",
          "default": "gemma4:e2b",
          "description": "Default model slug. Pick your fave and keep the flow moving."
        },
        "llem.requestTimeout": {
          "type": "number",
          "default": 300,
          "description": "How long LLeM waits before timing out, in seconds."
        },
        "llem.vaultPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to your markdown vault. Leave it blank and LLeM spins up its own stash."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "esbuild src/extension.ts --bundle --platform=node --external:vscode --outfile=out/extension.js",
    "package:vsix": "node scripts/package-vsix.mjs",
    "package:vsix:local": "LOCAL_VSIX=1 node scripts/package-vsix.mjs",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "@vercel/ncc": "^0.38.4",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "markdown-it": "^14.1.1"
  }
}
